{
  "scenario_id": "scenario_010",
  "scenario_name": "Single AGV - Obstacle Avoidance",
  "level": 2,
  "description": "Single AGV navigates from DOCK_A to DOCK_B avoiding a static wall obstacle in the center.",
  "factory_layout": "simple_warehouse",

  "agvs": [
    {
      "serial_number": "AGV_01",
      "initial_position": { "x": 5.0, "y": 5.0 },
      "battery_charge": 100.0,
      "speed": 0.06,
      "capabilities": ["pickup", "dropOff"]
    }
  ],

  "transport_requests": [
    {
      "request_id": "REQ_003",
      "pickup_node": "DOCK_A",
      "dropoff_node": "DOCK_B",
      "priority": 1,
      "payload_type": "tote"
    }
  ],

  "constraints": {
    "max_time_seconds": 90,
    "collision_tolerance": 1.5
  },

  "success_criteria": {
    "all_requests_delivered": true,
    "no_collisions": true,
    "battery_above": 30.0
  }
}
