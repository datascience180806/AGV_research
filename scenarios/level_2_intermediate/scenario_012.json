{
  "scenario_id": "scenario_012",
  "scenario_name": "Single AGV - Low Battery Charging",
  "level": 2,
  "description": "Single AGV starts with low battery (15%) and must navigate to the CHARGING_ZONE before executing the delivery request.",
  "factory_layout": "simple_warehouse",

  "agvs": [
    {
      "serial_number": "AGV_01",
      "initial_position": { "x": 25.0, "y": 35.0 },
      "battery_charge": 40.0,
      "speed": 0.06,
      "capabilities": ["pickup", "dropOff", "charge"]
    }
  ],

  "transport_requests": [
    {
      "request_id": "REQ_004",
      "pickup_node": "DOCK_B",
      "dropoff_node": "SHELF_B1",
      "priority": 1,
      "payload_type": "pallet"
    }
  ],

  "constraints": {
    "max_time_seconds": 150,
    "collision_tolerance": 1.5
  },

  "success_criteria": {
    "all_requests_delivered": true,
    "no_collisions": true,
    "battery_above": 40.0
  }
}
